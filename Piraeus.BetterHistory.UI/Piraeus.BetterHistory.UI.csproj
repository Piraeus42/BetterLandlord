<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>Piraeus.BetterHistory.UI</AssemblyName>
  </PropertyGroup>

  <!-- Shared source files linked from the mod project -->
  <ItemGroup>
    <!-- Model types -->
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\EventType.cs" Link="Models\EventType.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\GameEvent.cs" Link="Models\GameEvent.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\RunRecord.cs" Link="Models\RunRecord.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\RentCycle.cs" Link="Models\RentCycle.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\SingleOrArrayConverter.cs" Link="Models\SingleOrArrayConverter.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\RunSummary.cs" Link="Models\RunSummary.cs" />
    <Compile Include="..\Piraeus.BetterHistoryMod\Model\RunMeta.cs" Link="Models\RunMeta.cs" />
    <!-- IPC protocol types (RunListItem, etc.) -->
    <Compile Include="..\Piraeus.BetterHistoryMod\Ipc\PipeProtocol.cs" Link="Ipc\PipeProtocol.cs" />
  </ItemGroup>

  <!-- Game icons as content (loaded on demand, not embedded) -->
  <ItemGroup>
    <Content Include="Assets\Icons\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Copy UI exe + icons to mod directory so the game can launch it -->
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="if not exist &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod&quot; mkdir &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod&quot;&#xD;&#xA;if not exist &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\Assets\Icons&quot; mkdir &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\Assets\Icons&quot;&#xD;&#xA;xcopy /Y /I &quot;$(TargetDir)*.exe&quot; &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\&quot;&#xD;&#xA;xcopy /Y /I &quot;$(TargetDir)*.dll&quot; &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\&quot;&#xD;&#xA;xcopy /Y /I &quot;$(TargetDir)*.runtimeconfig.json&quot; &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\&quot;&#xD;&#xA;xcopy /Y /I &quot;$(TargetDir)Assets\Icons\*.png&quot; &quot;D:\steam\steamapps\common\Luck be a Landlord\GDWeave\mods\Piraeus.BetterHistoryMod\Assets\Icons\&quot;" />
  </Target>

</Project>
