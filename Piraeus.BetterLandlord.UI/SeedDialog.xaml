<Window x:Class="Piraeus.BetterLandlord.UI.SeedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Seed"
        Height="150" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#1E1E2E"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Label row -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Enter seed:"
                       FontSize="12" Foreground="#CDD6F4"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="?"
                    HorizontalAlignment="Right"
                    Width="24" Height="24"
                    FontSize="14" FontWeight="Bold"
                    Foreground="#FFFFFF"
                    Background="#4A6CF7"
                    BorderBrush="#4A6CF7"
                    Cursor="Help">
                <Button.ToolTip>
                    <ToolTip Background="#1E2030" BorderBrush="#45475A"
                             BorderThickness="1" Padding="10,8"
                             HasDropShadow="True">
                        <StackPanel>
                            <TextBlock FontSize="12" FontWeight="Bold" Foreground="#89B4FA"
                                       Text="种子输入规则" Margin="0,0,0,6" />
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap"
                                       MaxWidth="300">· 任意字符均可作为种子 — 数字(0-9)、英文大小写(A-Z, a-z)、中文、emoji、特殊符号等&#x0a;&#x0a;· 相同输入 → 相同游戏体验 (FNV-1a 哈希 → 确定性RNG)&#x0a;&#x0a;· 留空 → 完全随机种子&#x0a;&#x0a;· O/I 自动修正为 0/1 (避免与数字混淆)</TextBlock>
                        </StackPanel>
                    </ToolTip>
                </Button.ToolTip>
            </Button>
        </Grid>

        <!-- Input with watermark -->
        <Grid Grid.Row="1">
            <TextBox x:Name="SeedInput"
                     FontSize="14"
                     Background="#252538"
                     Foreground="#CDD6F4"
                     BorderBrush="#45475A"
                     BorderThickness="1"
                     Padding="8,6"
                     CaretBrush="#89B4FA"
                     SelectionBrush="#89B4FA"
                     SelectionOpacity="0.3"
                     TextChanged="SeedInput_TextChanged" />
            <TextBlock x:Name="Watermark"
                       Text="random"
                       FontSize="14"
                       Foreground="#6C7086"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="11,0,0,0" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    IsCancel="True"
                    Width="80" Height="28"
                    Background="#2D2D44"
                    Foreground="#CDD6F4"
                    BorderBrush="#45475A"
                    BorderThickness="1"
                    Cursor="Hand"
                    Margin="0,0,8,0" />
            <Button Content="Confirm"
                    Click="Confirm_Click"
                    Width="80" Height="28"
                    Background="#313255"
                    Foreground="#89B4FA"
                    BorderBrush="#45475A"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
